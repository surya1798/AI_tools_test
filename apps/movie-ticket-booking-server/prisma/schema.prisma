datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  createdAt   DateTime @default(now())
  email       String   @unique
  id          String   @id @default(cuid())
  password    String
  phoneNumber String?
  updatedAt   DateTime @updatedAt
}

model Appointment {
  appointmentDate DateTime?
  appointmentTime String?
  createdAt       DateTime  @default(now())
  doctorId        String?
  id              String    @id @default(cuid())
  patientId       String
  updatedAt       DateTime  @updatedAt
}
